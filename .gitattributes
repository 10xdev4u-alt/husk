* text=auto eol=lf

# Binary files (force binary to prevent diff noise)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp4 binary
*.mov binary
*.webm binary
*.mp3 binary
*.wav binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.lockb binary

# Source files (force LF)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
