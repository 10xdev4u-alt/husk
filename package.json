{
  "name": "@princetheprogrammerbtw/husk",
  "version": "0.4.1",
  "description": "Provider-agnostic agent harness — memory, tools, sub-agents, and observability wrapped around any LLM.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "husk": "./dist/cli/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "keywords": [
    "agent",
    "ai-agent",
    "llm",
    "claude",
    "anthropic",
    "openai",
    "gpt",
    "harness",
    "ai-tools",
    "mcp",
    "ai-agents"
  ],
  "author": "princetheprogrammerbtw <10xdev4u@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/10xdev4u-alt/husk.git"
  },
  "bugs": {
    "url": "https://github.com/10xdev4u-alt/husk/issues"
  },
  "homepage": "https://github.com/10xdev4u-alt/husk#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "trustedDependencies": ["@biomejs/biome"],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "openai": "^6.42.0"
  }
}
